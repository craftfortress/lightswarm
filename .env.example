# LIGHTSWARM Configuration
# Copy this file to .env and adjust as needed.

# Directory containing your project folders (each with a TODO.md)
# Default: ./projects (relative to lightswarm script)
# LIGHTSWARM_PROJECTS_DIR=/path/to/your/projects

# Claude model to use (default: sonnet)
# Options: sonnet, opus, haiku
# LIGHTSWARM_MODEL=sonnet

# Path to claude CLI binary (default: claude, found via PATH)
# LIGHTSWARM_CLAUDE_BIN=/path/to/claude

# Dashboard server port (default: 7777)
# LIGHTSWARM_PORT=7777
